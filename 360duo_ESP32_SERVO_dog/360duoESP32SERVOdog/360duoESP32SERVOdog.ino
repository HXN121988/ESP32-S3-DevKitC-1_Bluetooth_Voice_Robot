  display.clearDisplay();
  display.drawBitmap(0, 0, full_did_face, ful_width, full_height, SSD1306_WHITE);
  display.display();
  stopMovement();
}

// 趴下：保留显示，执行停止
void lieDown() {
  Serial.println("趴下");
  uart1.println("趴下");
  display.clearDisplay();
  display.drawBitmap(0, 0, full_did_face, ful_width, full_height, SSD1306_WHITE);
  display.display();
  stopMovement();
