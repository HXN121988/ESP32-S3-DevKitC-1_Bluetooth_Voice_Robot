// 跳舞：左右自转交替
void dance() {
  Serial.println("跳舞");
  uart1.println("跳舞");
  display.clearDisplay();
  display.drawBitmap(0, 0, full_smiley_face, ful_width, full_height, SSD1306_WHITE);
  display.display();

  for (int i = 0; i < 4; i++) {
    // 原地左转
    servoFL.write(LEFT_BACK);
    servoBL.write(LEFT_BACK);
    servoFR.write(RIGHT_FORWARD);
    servoBR.write(RIGHT_FORWARD);
    delay(500);
    // 原地右转
    servoFL.write(LEFT_FORWARD);
    servoBL.write(LEFT_FORWARD);
    servoFR.write(RIGHT_BACK);
    servoBR.write(RIGHT_BACK);
    delay(500);
  }
  stopMovement();
}

// ==================== 指令处理 ====================
void processCommand(char command) {
  // 指令过滤：只处理0-7的合法指令，屏蔽上电乱码
  if (command < 0 || command > 7) {
    return;
  }

  Serial.print("执行指令: ");
  Serial.println(command);
  uart1.print("执行指令: ");
  uart1.println(command);

  display.clearDisplay();
  display.setTextColor(SSD1306_WHITE);
  display.setTextSize(1);

  switch (command) {
    case forwardCmd:
      display.drawBitmap(0, 0, full_gogo_face, ful_width, full_height, SSD1306_WHITE);
      display.display();
      moveForward();
      break;
    case backwardCmd:
      display.drawBitmap(0, 0, full_gogo_face, ful_width, full_height, SSD1306_WHITE);
      display.display();
      moveBackward();
      break;
    case leftCmd:
      display.drawBitmap(0, 0, full_gogo_face, ful_width, full_height, SSD1306_WHITE);
      display.display();
      turnLeft();
      break;
    case rightCmd:
      display.drawBitmap(0, 0, full_gogo_face, ful_width, full_height, SSD1306_WHITE);
      display.display();
      turnRight();
      break;
    case stopCmd:
      display.drawBitmap(0, 0, full_smiley_face, ful_width, full_height, SSD1306_WHITE);
      display.display();
      stopMovement();
      break;
    case sitDownCmd:
      display.drawBitmap(0, 0, full_did_face, ful_width, full_height, SSD1306_WHITE);
      display.display();
      sitDown();
      break;
    case lieDownCmd:
      display.drawBitmap(0, 0, full_did_face, ful_width, full_height, SSD1306_WHITE);
      display.display();
      lieDown();
      break;
    case danceCmd:
      display.drawBitmap(0, 0, full_smiley_face, ful_width, full_height, SSD1306_WHITE);
      display.display();
      dance();
      break;
    default:
      break;
  }
}
